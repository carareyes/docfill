{
    "manifest_version": 3,
    "name": "DocFill",
    "version": "1.0",
    "description": "Autocomplete for Google docs: pairwise symbols and smart word suggestions",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://docs.google.com/document/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end",
            "world": "MAIN"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "DocFill"
    }
}